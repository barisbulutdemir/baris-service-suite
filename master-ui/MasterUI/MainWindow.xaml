<Window x:Class="MasterUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MasterUI"
        mc:Ignorable="d"
        Title="Tech Service Panel (Industrial Suite)" 
        Height="720" Width="1200"
        Background="#121212"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen">
    
    <Window.Resources>
        <!-- Custom Modern Scrollbar Style -->
        <!-- Theme Colors -->
        <SolidColorBrush x:Key="BgDark" Color="#121212"/>
        <SolidColorBrush x:Key="BgPanel" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="AccentBlue" Color="#007ACC"/>
        <SolidColorBrush x:Key="AccentRed" Color="#D9381E"/>
        <SolidColorBrush x:Key="TextLight" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="TextMuted" Color="#8A8A8A"/>

        <!-- Control templates & styles -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0096FF"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#333333"/>
                    <Setter Property="Foreground" Value="#666666"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DisconnectButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentRed}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="White" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4C3B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark Context Menu Style (bypasses Windows default theme white icon column) -->
        <Style x:Key="DarkContextMenu" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HasDropShadow" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Name="Border" 
                                Background="#1E1E1E" 
                                BorderBrush="#2D2D30" 
                                BorderThickness="1"
                                CornerRadius="5"
                                Padding="4">
                            <StackPanel IsItemsHost="True" 
                                        KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Context Menu MenuItem Style (removes white icon border box) -->
        <Style x:Key="DarkMenuItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#E5E5E5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder" Background="Transparent" Padding="10,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- Icon column: no border, no background -->
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                <!-- Header text -->
                                <ContentPresenter Grid.Column="1"
                                                  ContentSource="Header"
                                                  VerticalAlignment="Center"
                                                  Margin="6,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#3F3F46"/>
                                <Setter TargetName="ItemBorder" Property="CornerRadius" Value="3"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#555555"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Dark Separator Style -->
        <Style x:Key="DarkSeparator" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#2D2D30" Margin="8,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <!-- Sidebar (Sites) -->
            <ColumnDefinition x:Name="SidebarColumn" Width="280" MinWidth="200" MaxWidth="500"/>
            <!-- Splitter -->
            <ColumnDefinition Width="Auto"/>
            <!-- Main Content -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border x:Name="SidebarPanel" Grid.Column="0" Background="{StaticResource BgPanel}" BorderBrush="#252526" BorderThickness="0,0,1,0">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Brand Header -->
                <Grid Grid.Row="0" Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Technical Service Suite" FontSize="15" FontWeight="Black" Foreground="{StaticResource AccentBlue}"/>
                    </StackPanel>
                    <Button x:Name="CollapseSidebarBtn" Grid.Column="1" Click="ToggleSidebar_Click"
                            Background="Transparent" Foreground="{StaticResource TextMuted}" BorderThickness="0"
                            FontSize="16" Cursor="Hand" VerticalAlignment="Top"
                            ToolTip="Paneli Gizle" Content="«" Padding="4,2">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#2D2D30"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Separator Grid.Row="1" Background="#2D2D30" Margin="0,0,0,15"/>

                <!-- Sites List -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ŞANTİYELER" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMuted}" Margin="0,0,0,10"/>

                    <ListBox x:Name="SitesListBox" Grid.Row="1" 
                             Background="Transparent" BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             MouseDoubleClick="SitesListBox_MouseDoubleClick">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="Cursor" Value="Hand"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#2D2D30"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#3F3F46"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Background="Transparent">
                                    <Grid.ContextMenu>
                                        <ContextMenu Style="{StaticResource DarkContextMenu}">
                                            <MenuItem Header="Sadece Ekrana Bağlan" Click="MenuConnectScreenOnly_Click" Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="●" Foreground="#007ACC" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Sadece PLC Tüneli Aç" Click="MenuConnectTunnelOnly_Click" Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="●" Foreground="#107C41" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator Style="{StaticResource DarkSeparator}"/>
                                            <MenuItem Header="Ekran ve PLC Tüneli Aç" Click="MenuConnectWithTunnel_Click" Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="●" Foreground="#007ACC" FontWeight="Bold" VerticalAlignment="Center"/>
                                                        <TextBlock Text="●" Foreground="#107C41" FontWeight="Bold" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator Style="{StaticResource DarkSeparator}"/>
                                            <MenuItem Header="Şantiyeyi Yeniden Adlandır" Click="MenuRenameSite_Click" Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="✎" Foreground="#8A8A8A" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <Separator Style="{StaticResource DarkSeparator}"/>
                                            <MenuItem Header="Şantiyeyi Sistemden Sil" Click="MenuDeleteSite_Click" Style="{StaticResource DarkMenuItem}">
                                                <MenuItem.Icon>
                                                    <TextBlock Text="✕" Foreground="#D9381E" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Grid.ContextMenu>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Online/Offline indicator circle -->
                                    <Ellipse Grid.Column="0" Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="#E81123"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                        <Setter Property="Fill" Value="#107C41"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" Foreground="White"/>
                                        <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontSize="11" Foreground="{StaticResource TextMuted}" Margin="0,2,0,0"/>
                                        <TextBlock Text="{Binding LocationString}" FontSize="10" Foreground="#007ACC" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>

                <!-- Footer Connection State -->
                <Border Grid.Row="3" Background="#252526" CornerRadius="4" Padding="10" Margin="0,15,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ServerStatusIndicator" Width="8" Height="8" Fill="#E81123" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock x:Name="ServerStatusText" Text="Sunucu: Bağlı Değil" FontSize="11" Foreground="{StaticResource TextLight}"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- GRID SPLITTER (Resize Sidebar) -->
        <GridSplitter x:Name="SidebarSplitter" Grid.Column="1" Width="4" 
                      Background="#252526" HorizontalAlignment="Center" VerticalAlignment="Stretch"
                      Cursor="SizeWE"/>

        <!-- MAIN WINDOW VIEWPORT -->
        <Grid Grid.Column="2" Background="{StaticResource BgDark}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- UPPER BAR (Compact Header) -->
            <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="#252526" BorderThickness="0,0,0,1" Padding="12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Expand sidebar button (visible only when sidebar is collapsed) -->
                    <Button x:Name="ExpandSidebarBtn" Grid.Column="0" Click="ToggleSidebar_Click"
                            Background="#2D2D30" Foreground="{StaticResource TextLight}" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Margin="0,0,10,0"
                            Visibility="Collapsed" ToolTip="Şantiye Panelini Aç" Content="☰" Padding="8,4">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="BtnBorder" Property="Background" Value="#3F3F46"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <TextBlock x:Name="ActiveConnectionHeader" Grid.Column="1" 
                               Text="Boşta" 
                               FontSize="14" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    
                    <TextBlock x:Name="ActiveConnectionSubheader" Grid.Column="2" 
                               Text="Bağlanmak için bir şantiye seçin" 
                               FontSize="11" Foreground="{StaticResource TextMuted}" 
                               Margin="12,0,0,0" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                    <!-- HIZ TESTİ & OTURUMU KAPAT -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                        <ComboBox x:Name="QualityComboBox" Width="120" Margin="0,0,10,0" VerticalAlignment="Center"
                                  Background="#2D2D30" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46"
                                  SelectionChanged="QualityComboBox_SelectionChanged" Visibility="Collapsed">
                            <ComboBoxItem Content="Düşük (480p)" Tag="low" Background="#2D2D30" Foreground="White"/>
                            <ComboBoxItem Content="Orta (720p)" Tag="medium" IsSelected="True" Background="#2D2D30" Foreground="White"/>
                            <ComboBoxItem Content="Yüksek (1080p)" Tag="high" Background="#2D2D30" Foreground="White"/>
                            <ComboBoxItem Content="Ultra (Orijinal)" Tag="ultra" Background="#2D2D30" Foreground="White"/>
                        </ComboBox>
                        <Button x:Name="FullscreenButton" Style="{StaticResource ModernButton}" Background="#2D2D30" Foreground="White"
                                Content="Tam Ekran" Visibility="Collapsed" Click="FullscreenButton_Click" Margin="0,0,10,0" Padding="12,8"/>
                        <Button x:Name="SpeedTestButton" Style="{StaticResource ModernButton}" Background="#2D2D30" Foreground="White"
                                Content="Hız Testi Yap" Visibility="Collapsed" Click="SpeedTestButton_Click" Margin="0,0,10,0" Padding="12,8"/>
                        <Button x:Name="DisconnectButton" Style="{StaticResource DisconnectButton}" 
                                Content="OTURUMU KAPAT" Visibility="Collapsed" Click="DisconnectButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- TABS & SCREENS -->
            <TabControl x:Name="MainTabControl" Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="10">
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Visibility" Value="Collapsed"/> <!-- Hide tabs headers for embedded app style -->
                    </Style>
                </TabControl.ItemContainerStyle>
                
                <!-- Tab 1: Dashboard Logs (Idle Screen) -->
                <TabItem Header="Dashboard">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Log Terminal -->
                        <Border Grid.Row="0" Background="#0C0C0C" CornerRadius="6" BorderBrush="#2D2D30" BorderThickness="1" Padding="15">
                            <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                                <TextBox x:Name="LogTextBox" Background="Transparent" Foreground="#107C41" 
                                         BorderThickness="0" FontFamily="Consolas" FontSize="12"
                                         IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True"
                                         Text="[Sistem] Hazır. Bağlantı bekliyor..."/>
                            </ScrollViewer>
                        </Border>

                        <!-- Informational Help -->
                        <Border Grid.Row="1" Background="{StaticResource BgPanel}" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="Sihirli PLC Bağlantısı Kılavuzu:" FontSize="13" FontWeight="Bold" Foreground="{StaticResource TextLight}"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextMuted}" Margin="0,5,0,0" TextWrapping="Wrap" LineHeight="18">
                                    Bağlantı başarıyla sağlandıktan sonra, program arka planda bilgisayarınızda sanal bir ağ adaptörü oluşturacaktır. 
                                    TIA Portal, CX-Programmer veya OPC UA Client programlarında herhangi bir ayar yapmanıza gerek kalmadan, doğrudan PLC adresi olarak orijinal IP'yi (<Run Foreground="White" FontWeight="Bold">192.168.0.1</Run>) yazıp bağlanabilirsiniz. 
                                    Oturumu Kapattığınızda, bu sanal IP ve tünel sisteminizden otomatik olarak temizlenecektir.
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <!-- Tab 2: Embedded Screen Share (Active Screen) -->
                <TabItem Header="RemoteDesktop">
                    <Grid>
                        <Border Background="#1C1C1C" CornerRadius="6" BorderBrush="#2D2D30" BorderThickness="1" ClipToBounds="True">
                            <Grid>
                                <Grid x:Name="RemoteDesktopContainer">
                                    <!-- Remote desktop host control will be inserted dynamically here -->
                                </Grid>

                                <!-- File Transfer Progress Overlay (Non-blocking, bottom-right corner) -->
                                <Grid x:Name="FileTransferOverlay" Visibility="Collapsed">
                                    <Border Background="#1E1E1E" BorderBrush="#007ACC" BorderThickness="1.5" CornerRadius="8" Width="340" Height="125" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,20,20" Padding="15">
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock x:Name="FileTransferTitleText" Text="Dosya Gönderiliyor..." FontSize="12" FontWeight="Bold" Foreground="White" Margin="0,0,0,3"/>
                                            <TextBlock x:Name="FileTransferFileNameText" Text="dosya.exe" FontSize="10" Foreground="#A0A0A0" Margin="0,0,0,10" TextTrimming="CharacterEllipsis"/>
                                            <ProgressBar x:Name="FileTransferProgressBar" Height="6" Value="0" Maximum="100" Background="#333333" Foreground="#007ACC" BorderThickness="0" Margin="0,0,0,8"/>
                                            <TextBlock x:Name="FileTransferStatsText" Text="Hız: 0 KB/s | 0 / 0 MB" FontSize="10" Foreground="#007ACC"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- ADMIN EXCLUSION WARNING OVERLAY -->
        <Grid x:Name="AdminWarningOverlay" Grid.ColumnSpan="3" Background="#D9000000" Visibility="Collapsed">
            <Border Background="#1E1E1E" BorderBrush="{StaticResource AccentRed}" BorderThickness="2" 
                    CornerRadius="8" Width="480" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="30">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal">
                        <Path Width="24" Height="24" Fill="{StaticResource AccentRed}" Stretch="Fill" Margin="0,0,10,0"
                              Data="M12,2L1,21H23L12,2M12,6L19.53,19H4.47L12,6M11,10V14H13V10H11M11,16V18H13V16H11Z"/>
                        <TextBlock Text="YÖNETİCİ YETKİSİ GEREKLİ" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="Wintun sanal ağ adaptörünü kurmak ve PLC IP adresini (192.168.0.1) bilgisayarınıza tünellemek için bu uygulamanın Yönetici olarak çalıştırılması gerekmektedir.&#x0a;&#x0a;Lütfen uygulamayı kapatıp sağ tıklayarak 'Yönetici olarak çalıştır' seçeneğiyle yeniden başlatın." 
                               TextWrapping="Wrap" FontSize="13" Foreground="{StaticResource TextLight}" VerticalAlignment="Center" LineHeight="20"/>

                    <Button Grid.Row="2" Style="{StaticResource ModernButton}" Background="{StaticResource AccentRed}" 
                            Content="Uygulamadan Çık" HorizontalAlignment="Right" Width="120" Click="CloseAppButton_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
